    {
      "cell_type": "code",
      "source": [
        "import tensorflow as tf\n",
        "\n",
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "label_map = {\n",
        "    \"Cars\":0,\n",
        "    \"Drones\":1,\n",
        "    \"People\":2\n",
        "}\n",
        "\n",
        "X = []\n",
        "y = []\n",
        "\n",
        "for classe in classes:\n",
        "\n",
        "    arquivos = glob.glob(\n",
        "        folder_path + \"/\" + classe + \"/**/*.csv\",\n",
        "        recursive=True\n",
        "    )\n",
        "\n",
        "    arquivos = sorted(arquivos) # ordena arquivos temporalmente\n",
        "\n",
        "    print(f\"\\nCarregando classe: {classe}\")\n",
        "\n",
        "    # percorre usando janelas de 3 frames\n",
        "    for i in range(len(arquivos) - 2):\n",
        "\n",
        "        frame1 = pd.read_csv(\n",
        "            arquivos[i],\n",
        "            header=None\n",
        "        ).values.astype(np.float32)\n",
        "\n",
        "        frame2 = pd.read_csv(\n",
        "            arquivos[i+1],\n",
        "            header=None\n",
        "        ).values.astype(np.float32)\n",
        "\n",
        "        frame3 = pd.read_csv(\n",
        "            arquivos[i+2],\n",
        "            header=None\n",
        "        ).values.astype(np.float32)\n",
        "\n",
        "\n",
        "        frame1 = frame1.reshape(11,61)\n",
        "\n",
        "        frame2 = frame2.reshape(11,61)\n",
        "\n",
        "        frame3 = frame3.reshape(11,61)\n",
        "\n",
        "        # Normalização\n",
        "\n",
        "        frame1 = (\n",
        "            frame1 - np.mean(frame1)\n",
        "        ) / (\n",
        "            np.std(frame1) + 1e-8\n",
        "        )\n",
        "\n",
        "        frame2 = (\n",
        "            frame2 - np.mean(frame2)\n",
        "        ) / (\n",
        "            np.std(frame2) + 1e-8\n",
        "        )\n",
        "\n",
        "        frame3 = (\n",
        "            frame3 - np.mean(frame3)\n",
        "        ) / (\n",
        "            np.std(frame3) + 1e-8\n",
        "        )\n",
        "\n",
        "        # empilhando os 3 frames\n",
        "\n",
        "        matriz = np.stack(\n",
        "            [frame1, frame2, frame3],\n",
        "            axis=-1\n",
        "        )\n",
        "\n",
        "        X.append(matriz)\n",
        "\n",
        "        y.append(label_map[classe])\n",
        "\n",
        "X = np.array(X)\n",
        "\n",
        "y = np.array(y)\n",
        "\n",
        "print(\"\\nShape X:\", X.shape)\n",
        "\n",
        "print(\"Shape y:\", y.shape)\n",
        "\n",
        "# dividindo treino = 85% e teste = 15%\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X,\n",
        "    y,\n",
        "    test_size=0.15,\n",
        "    stratify=y,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "# dividindo treino = 70% e validação = 15%\n",
        "X_train, X_val, y_train, y_val = train_test_split(\n",
        "    X_train,\n",
        "    y_train,\n",
        "    test_size=0.1765,\n",
        "    stratify=y_train,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "\n",
        "print(\"\\nTreino:\", X_train.shape)\n",
        "\n",
        "print(\"Validação:\", X_val.shape)\n",
        "\n",
        "print(\"Teste:\", X_test.shape)\n"
      ],
